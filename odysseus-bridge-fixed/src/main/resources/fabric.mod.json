{
  "schemaVersion": 1,
  "id": "odysseus-bridge",
  "version": "0.1.0",
  "name": "Odysseus Bridge",
  "description": "Bridges Odysseus's Co-Pilot mode to Baritone. Runs a local WebSocket client, receives Baritone commands, and reports events back. No server chat traffic.",
  "authors": ["Gus Miller + Claude"],
  "contact": {
    "sources": "https://github.com/YOUR_GITHUB/odysseus-bridge-mod"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": ["com.odysseus.bridge.OdysseusBridge"]
  },
  "depends": {
    "fabricloader": ">=0.18.0",
    "fabric-api": "*",
    "minecraft": ">=26.1",
    "baritone": "*"
  },
  "custom": {
    "meteor-client:api-version": "0.5.0"
  }
}
